# WorkoutFlow - Client Environment Variables Example
# Copy this to .env and replace placeholders with your actual values

# Base URL of the backend API
VITE_API_URL=https://workoutflow-api.onrender.com

# VAPID Public Key for subscribing to web push notifications
# MUST MATCH the VAPID_PUBLIC_KEY in the backend .env
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
