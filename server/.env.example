# WorkoutFlow - Backend Environment Variables Example
# Copy this to .env and replace placeholders with your actual values

# Neon PostgreSQL connection string (pooled connection recommended)
DATABASE_URL=postgresql://username:password@ep-pooler.us-east-1.neon.tech/neondb?sslmode=require

# Port the Express server runs on
PORT=5000

# Node environment: development or production
NODE_ENV=production

# JWT signing key (use a long random secret key)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# VAPID Push Notification Keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@yourdomain.com

# URL of the deployed client frontend (for CORS configuration)
CLIENT_URL=https://workoutflow.vercel.app

# Secret token used to secure and validate cron job requests
CRON_SECRET=your_cron_secret_here
